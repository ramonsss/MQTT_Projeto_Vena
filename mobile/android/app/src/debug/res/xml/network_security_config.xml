<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY network security config (Android 9 / API 28+ cleartext override).
  Permits HTTP cleartext traffic to:
    - 10.0.2.2   (Android emulator → host machine)
    - 10.0.3.2   (Genymotion → host machine)
    - 192.168.0.0/16 (typical LAN for physical device over Wi-Fi)
    - 172.16.0.0/12  (Docker bridge networks)
  Do NOT ship this file in release builds.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false"/>

    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host alias -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Genymotion host alias -->
        <domain includeSubdomains="false">10.0.3.2</domain>
    </domain-config>

    <!-- Allow cleartext for the full private LAN (physical device) -->
    <!-- Pass BACKEND_URL dart-define with your LAN IP when running on a device -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.1.0</domain>
        <domain includeSubdomains="false">192.168.0.0</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.1.101</domain>
        <domain includeSubdomains="false">192.168.1.102</domain>
        <domain includeSubdomains="false">192.168.1.103</domain>
        <domain includeSubdomains="false">192.168.1.104</domain>
        <domain includeSubdomains="false">192.168.1.105</domain>
        <domain includeSubdomains="false">192.168.1.106</domain>
        <domain includeSubdomains="false">192.168.1.107</domain>
        <domain includeSubdomains="false">192.168.1.108</domain>
        <domain includeSubdomains="false">192.168.1.109</domain>
        <domain includeSubdomains="false">192.168.1.110</domain>
    </domain-config>

    <!-- Docker bridge networks -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">172.17.0.1</domain>
        <domain includeSubdomains="false">172.18.0.1</domain>
        <domain includeSubdomains="false">172.21.0.1</domain>
    </domain-config>

    <!-- localhost (unit / integration tests on device) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
