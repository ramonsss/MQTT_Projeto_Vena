# =============================================================================
# Vena — variáveis de ambiente
# Copie este arquivo para .env na raiz do projeto e preencha os valores reais.
# O .env NUNCA deve ser commitado (já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (usado pelo Docker Compose e pelo backend)
# -----------------------------------------------------------------------------
POSTGRES_USER=vena
POSTGRES_PASSWORD=vena_dev_local
POSTGRES_DB=vena

# -----------------------------------------------------------------------------
# Backend FastAPI
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vena:vena_dev_local@localhost:5432/vena

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883

# JWT — troque por um segredo longo e aleatório em produção
# Gere um com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Validade do refresh token (dias). Padrão: 30 dias.
JWT_REFRESH_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# Client ID do projeto no Google Cloud Console (APIs & Services → Credentials).
# Usado pelo backend para validar o id_token enviado pelo app.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Pairing de dispositivos
# -----------------------------------------------------------------------------
# Segredo de fábrica. O código de pairing de cada ESP32 é derivado como:
#   SHA-256(MAC_ADDRESS + PAIRING_SECRET)[:8].upper()
# Mantenha este valor privado — quem o tiver consegue calcular o pairing code
# de qualquer dispositivo pelo MAC address.
# Gere um com: python -c "import secrets; print(secrets.token_hex(32))"
PAIRING_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# MQTT JWT
# -----------------------------------------------------------------------------
# Validade do JWT que o app usa para conectar ao broker MQTT (minutos).
MQTT_JWT_EXPIRE_MINUTES=60

# Validade do JWT gravado na NVS do ESP32 (dias). Padrão: 365 dias (1 ano).
DEVICE_JWT_EXPIRE_DAYS=365

# -----------------------------------------------------------------------------
# Mobile — Flutter --dart-define (não é arquivo .env; é passado no build)
# -----------------------------------------------------------------------------
# Emulador Android (padrões já embutidos, sem flags necessárias):
#   flutter run
#
# Dispositivo físico (substitua pelo IP local do PC na rede Wi-Fi):
#   flutter run \
#     --dart-define=BACKEND_URL=http://192.168.x.x:8000 \
#     --dart-define=GOOGLE_CLIENT_ID=<WEB_CLIENT_ID>.apps.googleusercontent.com
#
# BACKEND_URL      — URL base do FastAPI (sem barra no fim)
# GOOGLE_CLIENT_ID — Web client ID do Google Cloud Console
#                    (APIs & Services → Credentials → OAuth 2.0 → Web client)
#                    O mesmo valor de GOOGLE_CLIENT_ID do backend acima.
#
# Nota: MQTT_HOST e MQTT_PORT NÃO são dart-defines. O app obtém o host/port
# dinamicamente via POST /mqtt/credentials respondido pelo backend.
# Se o broker estiver offline, o app continua funcional (status desconectado
# com reconexão automática em background).
